       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Profile of Observation as defined for South Fiji." ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
